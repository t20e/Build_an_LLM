        <mxCell id="sC2nh2z6wBofH9oqhz0A-87" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=light-dark(#f9cbdf, #B9E0A5);fillColor=none;align=center;verticalAlign=middle;rounded=0;strokeWidth=3;" value="&lt;span style=&quot;font-size: 14px;&quot;&gt;&lt;b&gt;Broadcasting:&lt;/b&gt;&lt;/span&gt;&lt;div&gt;TODO: add infor here about,&amp;nbsp;&lt;li style=&quot;font-family: &amp;quot;Google Sans Text&amp;quot;, sans-serif !important; line-height: 1.15 !important; margin-top: 0px !important;&quot;&gt;&lt;p data-path-to-node=&quot;2,3,0&quot; style=&quot;line-height: 1.15 !important; margin-top: 0px !important;&quot;&gt;Broadcast&amp;nbsp;&lt;span class=&quot;math-inline&quot; data-math=&quot;K&quot; data-index-in-node=&quot;10&quot; style=&quot;line-height: 1.15 !important; margin-top: 0px !important;&quot;&gt;K&amp;nbsp;&lt;/span&gt;and&amp;nbsp;&lt;span class=&quot;math-inline&quot; data-math=&quot;V&quot; data-index-in-node=&quot;16&quot; style=&quot;line-height: 1.15 !important; margin-top: 0px !important;&quot;&gt;V&lt;/span&gt;&amp;nbsp;to match&amp;nbsp;&lt;span class=&quot;math-inline&quot; data-math=&quot;Q&quot; data-index-in-node=&quot;27&quot; style=&quot;line-height: 1.15 !important; margin-top: 0px !important;&quot;&gt;Q&lt;/span&gt;&#39;s head count.&amp;nbsp;&lt;b&gt;After RoPE&lt;/b&gt;&amp;nbsp;has been applied&lt;/p&gt;&lt;/li&gt;&lt;li style=&quot;font-family: &amp;quot;Google Sans Text&amp;quot;, sans-serif !important; line-height: 1.15 !important; margin-top: 0px !important;&quot;&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;/li&gt;&lt;/div&gt;" vertex="1">
