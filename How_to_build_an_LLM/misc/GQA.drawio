          </mxGeometry>
        </mxCell>
        <mxCell id="sC2nh2z6wBofH9oqhz0A-82" edge="1" parent="sC2nh2z6wBofH9oqhz0A-66" source="ozRH1OG0Ai7oIMEXacTK-6" style="endArrow=classic;html=1;rounded=0;exitX=0.5;exitY=0;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;strokeColor=#FFC60E;" target="sC2nh2z6wBofH9oqhz0A-79" value="">
          <mxGeometry height="50" relative="1" width="50" as="geometry">
            <mxPoint x="200" y="484" as="sourcePoint" />
            <mxPoint x="300" y="444" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="sC2nh2z6wBofH9oqhz0A-83" parent="sC2nh2z6wBofH9oqhz0A-66" style="text;html=1;whiteSpace=wrap;strokeColor=light-dark(#f9cbdf, #B9E0A5);fillColor=none;align=center;verticalAlign=middle;rounded=0;strokeWidth=3;" value="&lt;span style=&quot;font-size: 14px;&quot;&gt;After applying &lt;/span&gt;&lt;b style=&quot;font-size: 14px;&quot;&gt;RoPE&lt;/b&gt;&lt;span style=&quot;font-size: 14px;&quot;&gt;, we cache the &lt;/span&gt;&lt;b style=&quot;font-size: 14px;&quot;&gt;rotated K&lt;/b&gt;&lt;span style=&quot;font-size: 14px;&quot;&gt; and the &lt;/span&gt;&lt;b style=&quot;font-size: 14px;&quot;&gt;un-rotated V&lt;/b&gt;&lt;span style=&quot;font-size: 14px;&quot;&gt; by concatenating&amp;nbsp;them with the past tokens&#39; cache.&lt;/span&gt;" vertex="1">
          <mxGeometry height="96" width="215" x="285" y="464" as="geometry" />
        </mxCell>
        <mxCell id="sC2nh2z6wBofH9oqhz0A-86" edge="1" parent="sC2nh2z6wBofH9oqhz0A-66" source="sC2nh2z6wBofH9oqhz0A-83" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;strokeColor=light-dark(#f9cbdf, #ff6ee6);exitX=0.5;exitY=0;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;" target="sC2nh2z6wBofH9oqhz0A-79" value="">
          <mxGeometry height="50" relative="1" width="50" as="geometry">
            <mxPoint x="270" y="464" as="sourcePoint" />
            <mxPoint x="320" y="414" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="sC2nh2z6wBofH9oqhz0A-57" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=#FF22AE;fillColor=none;align=center;verticalAlign=middle;rounded=0;perimeterSpacing=0;" value="&lt;font style=&quot;font-size: 14px;&quot;&gt;&lt;b&gt;Projections:&lt;/b&gt;&lt;/font&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;The difference between the &lt;b&gt;MHA&lt;/b&gt; and &lt;b&gt;GQA&lt;/b&gt; is how they project the input &lt;b&gt;X&lt;/b&gt; into the &lt;b&gt;Q&lt;/b&gt;, &lt;b&gt;K&lt;/b&gt;, and &lt;b&gt;V&lt;/b&gt; matrices.&amp;nbsp;&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;In&amp;nbsp;&lt;/font&gt;&lt;b style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); font-size: 14px;&quot;&gt;GQA &lt;/b&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); font-size: 14px;&quot;&gt;the&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); font-size: 14px;&quot;&gt;&amp;nbsp;K and V heads are the same size, and they have fewer heads than the Q. This saves memory.&lt;/span&gt;&lt;/div&gt;" vertex="1">
